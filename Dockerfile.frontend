# === Frontend Streamlit Dockerfile ===
FROM python:3.10-slim

WORKDIR /app
COPY requirements.txt .

# Optimize installation specifically for frontend needs
RUN pip install --no-cache-dir streamlit requests pydantic-settings

COPY ./app ./app

# Expose Space mapping
EXPOSE 7860

# Streamlit Health Configs
ENV STREAMLIT_SERVER_PORT=7860
ENV STREAMLIT_SERVER_ADDRESS=0.0.0.0

CMD ["streamlit", "run", "app/frontend/streamlit_app.py", "--server.port=7860", "--server.address=0.0.0.0"]
